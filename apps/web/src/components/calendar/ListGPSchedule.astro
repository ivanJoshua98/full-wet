---
import TimeSchedule from '../calendar/TimeSchedule.astro';
import CalendarIcon from '../icons/CalendarIcon.astro';
import WorldIcon from '../icons/WorldIcon.astro';

const { race } = Astro.props;

const sessionsUnsorted = [
  { name: 'Práctica Libre 1', date: race?.firstPractice },
  { name: 'Práctica Libre 2', date: race?.secondPractice },
  { name: 'Práctica Libre 3', date: race?.thirdPractice },
  { name: 'Clasificación Sprint / Shootout', date: race?.sprint },
  { name: 'Clasificación', date: race?.qualifying },
  { name: 'Carrera', date: race?.date },
];

// Se omiten variables sin definir en find (ej: no hay prácticas 2 si hay sprint)
// y luego se ordena la matriz en base de la fecha ASC.
const sessions = sessionsUnsorted
  .filter(s => s.date)
  .sort((a, b) => new Date(a.date!).getTime() - new Date(b.date!).getTime());
---

<div class="bg-brand-card border border-white/5 rounded-2xl overflow-hidden py-4 px-1 md:p-8 my-5 w-full h-fit">
  <!-- Cabecera de la tabla -->
  <div class="bg-gradient-to-r from-brand-dark to-brand-card p-4 border-b border-white/5">
    <div class="flex items-center gap-3">
      <div class="w-1.5 h-6 bg-brand-accent rounded-full shadow-[0_0_8px_#00D1FF]"></div>
      <h2 class="font-black text-white tracking-wide uppercase">Cronograma del {race?.name || 'Fin de Semana'}</h2>
    </div>
    <p class="text-brand-muted mt-2 ml-5 flex items-start gap-2 text-sm font-medium">
      <WorldIcon size="h-5 w-5"/>
      <span>Horarios adaptados a tu zona horaria local<span class="timezone-display text-brand-accent/80 font-bold ml-1"></span></span>
    </p>
  </div>
  <!-- Contenedor del cronograma de eventos -->
  <div class="p-1 md:p-2 space-y-2">
    {sessions.length > 0 ? (
      sessions.map((session) => { 
        // Se marca si es la gran carrera para destacarla
        const isRace = session.name === 'Carrera';
        return (
          <TimeSchedule isRace={isRace} session={session} />
        )
      })
    ) : (
      <div class="p-10 flex flex-col items-center text-center">
        <CalendarIcon size="h-12 w-12" extraClass="text-brand-muted mb-4 opacity-50"/>
        <p class="text-brand-muted text-lg font-medium">No hay información de sesiones programadas para el evento.</p>
      </div>
    )}
  </div>
</div>

<script>
  function applyTimezoneDisplay() {
    const tzDisplays = document.querySelectorAll('.timezone-display');
    if (tzDisplays.length === 0) return;
    
    try {
      // Intenta obtener la zona horaria del sistema (Ej: America/Buenos_Aires)
      const timeZone = Intl.DateTimeFormat().resolvedOptions().timeZone;
      if (timeZone) {
        // Reemplaza los guiones bajos por espacios para mejor legibilidad
        const readableTimeZone = timeZone.replace(/_/g, ' ');
        tzDisplays.forEach(el => {
          el.textContent = `(${readableTimeZone})`;
        });
      }
    } catch (e) {
      console.warn("Timezone no pudo ser detectada.");
    }
  }

  // Ejecutar al cargar la página en Astro
  document.addEventListener('astro:page-load', applyTimezoneDisplay);
  applyTimezoneDisplay();
</script>
