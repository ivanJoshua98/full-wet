---
import { getMonthName, getDayNumber, getTime } from "../../utils/dateFormatter";
import ClockIcon from "../icons/ClockIcon.astro";

const currentSeason = new Date().getFullYear();
const { isNextRace = false, race } = Astro.props;
---

<a href={race.seasonYear === currentSeason ? `/current-season/${race.id}` : `/seasons/${race.seasonYear}/${race.id}`}>
  <div class={`race-details-item flex flex-row gap-2 justify-between items-center p-2 rounded-xl transition-all duration-300 group hover:translate-x-1 ${
    isNextRace 
      ? 'bg-gradient-to-r from-brand-accent/10 to-transparent border border-brand-accent/30 ring-1 ring-brand-accent/20 mt-4 shadow-[0_0_15px_rgba(0,209,255,0.05)]' 
      : 'hover:bg-white/[0.03] border border-transparent hover:border-white/10'
  }`} data-date={race.date}>
  
    <!-- Bloque: Calendario Fecha -->
    <div class={`flex flex-col justify-center items-center border rounded-lg p-1 min-w-[40px] md:min-w-[50px] ${
      isNextRace ? 'bg-brand-accent/10 border-brand-accent/40 shadow-inner' : 'bg-brand-dark/50 border-white/10'
    }`}>
      <span data-js="month" class={`text-[10px] uppercase font-bold tracking-widest ${isNextRace ? 'text-brand-accent' : 'text-brand-muted'}`}>
        {getMonthName(race.date)}
      </span>
      <span data-js="day-number" class={`font-mono font-black ${isNextRace ? 'text-white' : 'text-slate-200'}`}>
        {getDayNumber(race.date)}
      </span>
    </div>
  
    <!-- Bloque: Nombre de la carrera -->
    <div class="w-full flex flex-col ml-2">
      <p class={`font-black uppercase tracking-widest text-sm md:text-base text-balance leading-tight ${
        isNextRace ? 'text-brand-accent drop-shadow-[0_0_8px_rgba(0,209,255,0.5)]' : 'text-slate-200'
      }`}>
        {race.name}
      </p>
      <!-- Bloque: Nombre del circuito -->
      <p class={`text-xs font-medium tracking-wide text-balance mt-0.5 flex items-center gap-1 ${
        isNextRace ? 'text-brand-accent/80' : 'text-brand-muted'
      }`}>
        {race.circuit.name}
      </p>
    </div>
  
    <!-- Bloque: Hora -->
    <div class="w-fit flex justify-end items-center gap-2">
      <ClockIcon size="h-5 w-5" extraClass="text-brand-muted group-hover:text-brand-accent transition-colors duration-300"/>
      <span data-js="time" class={`font-mono text-lg md:text-2xl font-bold tracking-tight ${isNextRace ? 'text-white drop-shadow-[0_0_8px_rgba(255,255,255,0.3)]' : 'text-slate-100'}`}>
        {getTime(race.date)}
      </span>
      <span class="text-brand-muted font-bold text-sm mt-1">HS</span>
    </div>
  
  </div>
</a>

<script>
  function formatRaceDetailsTimes() {
    const items = document.querySelectorAll('.race-details-item');
    
    items.forEach(item => {
      const dateStr = item.getAttribute('data-date');
      if (!dateStr || dateStr === 'undefined') return;

      const date = new Date(dateStr);
      
      const monthEl = item.querySelector('[data-js="month"]');
      const dayNumEl = item.querySelector('[data-js="day-number"]');
      const timeEl = item.querySelector('[data-js="time"]');

      if (monthEl) {
        monthEl.textContent = date.toLocaleDateString('es', { month: 'short' }).replace('.', '');
      }
      if (dayNumEl) {
        dayNumEl.textContent = date.toLocaleDateString('es', { day: '2-digit' });
      }
      if (timeEl) {
        timeEl.textContent = date.toLocaleTimeString('es', { 
          hour: '2-digit', 
          minute: '2-digit', 
          hour12: false 
        });
      }
    });
  }

  // Ejecutar en carga inicial y transiciones de página en Astro
  document.addEventListener('astro:page-load', formatRaceDetailsTimes);
  formatRaceDetailsTimes();
</script>