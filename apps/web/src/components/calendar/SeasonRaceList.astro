---
import CalendarIcon from "../icons/CalendarIcon.astro";
import WorldIcon from "../icons/WorldIcon.astro";
import { type models } from "types";
import RaceDetails from "./RaceDetails.astro";
import { getRacesByYear } from "../../controllers/raceController";
import TouchIcon from "../icons/TouchIcon.astro";

const { season } = Astro.props;

const races = await getRacesByYear(season);
let nextRace = null;

if (Number(season) === new Date().getFullYear()) {
  // La API los retorna ordenados ascendentemente, por lo que la primera carrera que sea mayor o igual a la fecha actual es la próxima carrera
  const now = Date.now();
  nextRace = races.find((race: models.Race) => new Date(race.date as any).getTime() >= now);
}
---
<div class="w-full px-0 md:px-4">
<div class="bg-brand-card border border-white/5 rounded-2xl overflow-hidden py-4 px-1 md:p-2 my-4 md:my-2 w-full h-fit season-race-list-container">
  <!-- Cabecera de la tabla -->
  <div class="bg-gradient-to-r from-brand-dark to-brand-card p-4 border-b border-white/5">
    <div class="flex items-center gap-3">
      <div class="w-1.5 h-6 bg-brand-accent rounded-full shadow-[0_0_8px_#00D1FF]"></div>
      <h2 class="font-black text-white tracking-wide uppercase">Resumen de la temporada {season}</h2>
    </div>
    <p class="text-brand-muted mt-2 ml-5 flex items-start gap-2 text-sm font-medium">
      <WorldIcon size="h-5 w-5"/>
      <span>Horarios adaptados a tu zona horaria local<span class="timezone-display text-brand-accent/80 font-bold ml-1"></span></span>
    </p>
    <p class="text-brand-muted mt-1 ml-5 flex items-start gap-2 text-sm font-medium">
      <TouchIcon size="h-4 w-4"/>
      Haz clic en una carrera para ver los resultados
    </p>
  </div>
  <!-- Contenedor del cronograma de eventos -->
  <div class="p-1 md:p-2 space-y-2">
    {races.length > 0 ? (
      races.map((race: models.Race, index: number) => { 
        // Se marca la próxima carrera para destacarla
        const isNextRace = race.name === nextRace?.name;
        return (
          <div class={`race-item ${index >= 3 ? 'hidden' : ''}`}>
            <RaceDetails isNextRace={isNextRace} race={race} />
          </div>
        )
      })
    ) : (
      <div class="p-10 flex flex-col items-center text-center">
        <CalendarIcon size="h-12 w-12" extraClass="text-brand-muted mb-4 opacity-50"/>
        <p class="text-brand-muted text-lg font-medium">No hay información de sesiones programadas.</p>
      </div>
    )}
    {races.length > 3 && (
      <div class="flex justify-center mt-4">
        <button class="expand-season-race-list-btn bg-brand-accent/10 hover:bg-brand-accent/20 text-brand-accent font-semibold py-2.5 px-6 rounded-full transition-all duration-300 shadow hover:shadow-brand-accent/20">
          Ver tabla completa
        </button>
      </div>
    )}
  </div>
</div>
</div>

<script>
  function setupStandingsToggle () {
    const containers = document.querySelectorAll('.season-race-list-container');
    
    containers.forEach(container => {
      const btn = container.querySelector('.expand-season-race-list-btn');
      const standingItems = container.querySelectorAll('.race-item');
      
      if (btn) {
        // Clonar botón para remover event listeners anteriores si se recargase
        const newBtn = btn.cloneNode(true);
        btn.parentNode?.replaceChild(newBtn, btn);
        
        let isExpanded = false;
        
        newBtn.addEventListener('click', () => {
          isExpanded = !isExpanded;
          
          standingItems.forEach((item, index) => {
            if (index >= 3) {
              if (isExpanded) {
                item.classList.remove('hidden');
                // Efecto de aparición simple
                item.animate([
                  { opacity: 0, transform: 'translateY(-10px)' },
                  { opacity: 1, transform: 'translateY(0)' }
                ], {
                  duration: 250,
                  easing: 'ease-out',
                  fill: 'forwards'
                });
              } else {
                item.classList.add('hidden');
              }
            }
          });
          
          newBtn.textContent = isExpanded ? 'Ocultar tabla' : 'Ver tabla completa';
        });
      }
    });
  };

  function applyTimezoneDisplay() {
    const tzDisplays = document.querySelectorAll('.timezone-display');
    if (tzDisplays.length === 0) return;
    
    try {
      // Intenta obtener la zona horaria del sistema (Ej: America/Buenos_Aires)
      const timeZone = Intl.DateTimeFormat().resolvedOptions().timeZone;
      if (timeZone) {
        // Reemplaza los guiones bajos por espacios para mejor legibilidad
        const readableTimeZone = timeZone.replace(/_/g, ' ');
        tzDisplays.forEach(el => {
          el.textContent = `(${readableTimeZone})`;
        });
      }
    } catch (e) {
      console.warn("Timezone no pudo ser detectada.");
    }
  }

  function loadsFunctions () {
    setupStandingsToggle();
    applyTimezoneDisplay();
  }
  // Compatible con ViewTransitions de Astro
  loadsFunctions();
  document.addEventListener('astro:page-load', loadsFunctions);
</script>