---
import type { models } from "types";
import { getConstructorStandings } from "../../controllers/championshipController";
import CalendarIcon from "../icons/CalendarIcon.astro";
import ConstructorStandingDetails from "./ConstructorStandingDetails.astro";

const { season } = Astro.props;
const constructorStandings = await getConstructorStandings(season);
---

<div 
  id={`constructor-standings-${season}`}
  class="bg-brand-card border border-white/5 rounded-2xl overflow-hidden py-4 px-1 md:px-2 my-4 md:my-2 w-full md:w-5/6 h-fit constructor-standings-container">
  <!-- Cabecera de la tabla -->
  <div class="bg-gradient-to-r from-brand-dark to-brand-card p-4 border-b border-white/5">
    <div class="flex items-center gap-3">
      <div class="w-1.5 h-6 bg-brand-accent rounded-full shadow-[0_0_8px_#00D1FF]"></div>
      <h2 class="font-black text-white tracking-wide uppercase">Campeonato de constructores {constructorStandings[0].seasonYear || '---'}</h2>
    </div>
  </div>
  <!-- Contenedor de la tabla de posiciones -->
  <div class="p-1 md:p-2 space-y-2">
    {constructorStandings.length > 0 ? (
      constructorStandings.map((constructorStanding: models.ConstructorStanding, index: number) => { 
        return (
          <div class={`constructor-standing-item ${index >= 3 ? 'hidden' : ''}`}>
            <ConstructorStandingDetails constructorStanding={constructorStanding} />
          </div>
        )
      })
    ) : (
      <div class="p-10 flex flex-col items-center text-center">
        <CalendarIcon size="h-12 w-12" extraClass="text-brand-muted mb-4 opacity-50"/>
        <p class="text-brand-muted text-lg font-medium">No hay información del campeonato.</p>
      </div>
    )}
    {constructorStandings.length > 3 && (
      <div class="flex justify-center mt-4">
        <button class="expand-constructor-standings-btn bg-brand-accent/10 hover:bg-brand-accent/20 text-brand-accent font-semibold py-2.5 px-6 rounded-full transition-all duration-300 shadow hover:shadow-brand-accent/20">
          Ver tabla completa
        </button>
      </div>
    )}
  </div>
</div>

<script>
  const setupStandingsToggle = () => {
    const containers = document.querySelectorAll('.constructor-standings-container');
    
    containers.forEach(container => {
      const btn = container.querySelector('.expand-constructor-standings-btn');
      const standingItems = container.querySelectorAll('.constructor-standing-item');
      
      if (btn) {
        // Clonar botón para remover event listeners anteriores si se recargase
        const newBtn = btn.cloneNode(true);
        btn.parentNode?.replaceChild(newBtn, btn);
        
        let isExpanded = false;
        
        newBtn.addEventListener('click', () => {
          isExpanded = !isExpanded;
          
          standingItems.forEach((item, index) => {
            if (index >= 3) {
              if (isExpanded) {
                item.classList.remove('hidden');
                // Efecto de aparición simple
                item.animate([
                  { opacity: 0, transform: 'translateY(-10px)' },
                  { opacity: 1, transform: 'translateY(0)' }
                ], {
                  duration: 250,
                  easing: 'ease-out',
                  fill: 'forwards'
                });
              } else {
                item.classList.add('hidden');
              }
            }
          });
          
          newBtn.textContent = isExpanded ? 'Ocultar tabla' : 'Ver tabla completa';
        });
      }
    });
  };

  setupStandingsToggle();
  // Compatible con ViewTransitions de Astro
  document.addEventListener('astro:page-load', setupStandingsToggle);
</script>