---
const year = new Date().getFullYear();
---


<div class="h-full min-h-screen w-full md:min-w-[20vw] md:max-w-[25vw] flex-1 px-4">
  <nav class="py-6 text-slate-100" aria-label="Navegación principal">
    <h3 class="px-2 text-xs font-semibold text-gray-400 tracking-wider mb-4">
      DESTACADO
    </h3>
    <ul class="space-y-1 mb-8">
      <li>
        <a href="/" class="flex items-center px-2 py-3 text-base rounded-lg hover:bg-slate-800 transition-colors">
          Inicio
        </a>
      </li>
      <li>
        <a href={`/seasons/${year}`} class="flex items-center px-2 py-3 text-base rounded-lg hover:bg-slate-800 transition-colors">
          Temporada {year}
        </a>
      </li>
      <li>
        <a href={`/seasons/${year}#driver-standings-${year}`} class="flex items-center px-2 py-3 text-base rounded-lg hover:bg-slate-800 transition-colors">
          Campeonato de pilotos {year}
        </a>
      </li>
      <li>
        <a href={`/seasons/${year}#constructor-standings-${year}`} class="flex items-center px-2 py-3 text-base rounded-lg hover:bg-slate-800 transition-colors">
          Campeonato de constructores {year}
        </a>
      </li>
      <li>
        <a href={`/seasons/`} class="flex items-center px-2 py-3 text-base rounded-lg hover:bg-slate-800 transition-colors">
          Temporadas pasadas
        </a>
      </li>
    </ul>
  </nav>
  <!-- Footer del Drawer -->
  <div class="p-4 border-t border-slate-800 text-center">
    <p class="text-xs text-gray-400">© 2026 Full Wet.</p>
  </div>
</div>