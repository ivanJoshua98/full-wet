---
import CloseIcon from "../icons/CloseIcon.astro";
import Drawer from "./Drawer.astro";
---
<div 
  id="mobile-menu-drawer"
  class="fixed top-0 left-0 h-full w-72 max-w-[85vw] bg-slate-900 shadow-2xl z-50 transform 
    -translate-x-full transition-transform duration-300 ease-in-out flex flex-col"
>
  <!-- Header del Drawer -->
  <div class="px-6 py-5 flex items-center justify-between border-b border-slate-800">
    <a href="/"><img src="/Rueda+Full-Wet-Menu.svg" alt="Full Wet" class="w-[150px]"></a> 
    <button id="close-mobile-menu" class="p-2 -mr-2 rounded-full text-gray-400 transition-colors" aria-label="Cerrar menú">
      <CloseIcon size="h-6 w-6"/>
    </button>
  </div>
  <Drawer />
</div>