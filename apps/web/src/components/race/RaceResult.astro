---
import type { models } from "types";
import { getRaceResults } from "../../controllers/raceController";
import CalendarIcon from "../icons/CalendarIcon.astro";
import DriverResult from "./DriverResult.astro";

const { raceId } = Astro.props;

const table = await getRaceResults(raceId);
---

<div class="bg-brand-card border border-white/5 rounded-2xl overflow-hidden py-4 px-1 md:p-8 my-5 w-full md:w-5/6 h-fit">
  <!-- Cabecera de la tabla -->
  <div class="bg-gradient-to-r from-brand-dark to-brand-card p-4 border-b border-white/5">
    <div class="flex items-center gap-3">
      <div class="w-1.5 h-6 bg-brand-accent rounded-full shadow-[0_0_8px_#00D1FF]"></div>
      <h2 class="font-black text-white tracking-wide uppercase">Resultados {table.race?.name} {table.race?.seasonYear}</h2>
    </div>
  </div>
  <!-- Contenedor del cronograma de eventos -->
  <div class="p-1 md:p-2 space-y-2">
    {table.results.length > 0 ? (
      table.results.map((result: models.RaceResult) => { 
        return (
          <DriverResult result={result} firstDriver={table.results[0]} />
        )
      })
    ) : (
      <div class="p-10 flex flex-col items-center text-center">
        <CalendarIcon size="h-12 w-12" extraClass="text-brand-muted mb-4 opacity-50"/>
        <p class="text-brand-muted text-lg font-medium">No hay información del evento.</p>
      </div>
    )}
  </div>
</div>