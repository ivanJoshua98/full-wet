---
export const prerender = false;

import ListGPSchedule from '../components/calendar/ListGPSchedule.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/header/Header.astro';
import Drawer from '../components/navigation/Drawer.astro';
import BaseSectionLayout from '../layouts/BaseSectionLayout.astro';
import NextEventCountdown from '../components/calendar/NextEventCountdown.astro';
import { getNextRace } from "../controllers/raceController";

const year = new Date().getFullYear();
const nextRace = await getNextRace(year);
---

<BaseLayout title="Full Wet" description="Formula 1 en vivo. Resultados, horarios, calendario, pilotos, equipos y todo sobre la categoría reina del automovilismo.">
	<Header />
	<div class="flex">
		<div class="hidden md:block"><Drawer /></div>
		<BaseSectionLayout>
			<NextEventCountdown nextRace={nextRace} />
			<ListGPSchedule race={nextRace} />
		</BaseSectionLayout>
	</div>
</BaseLayout>
