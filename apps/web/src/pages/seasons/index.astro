---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPastSeasons } from '../../controllers/seasonsController';
import BodyLayout from '../../layouts/BodyLayout.astro';
import CalendarIcon from '../../components/icons/CalendarIcon.astro';

const seasons = await getPastSeasons();
---

<BaseLayout title="Full Wet" description="Formula 1 en vivo. Resultados, horarios, calendario, pilotos, equipos y todo sobre la categoría reina del automovilismo.">
	<BodyLayout>
    <div class="bg-brand-card border border-white/5 rounded-2xl overflow-hidden py-4 px-1 md:p-8 my-5 w-full md:w-5/6 h-fit">
      <!-- Cabecera de la tabla -->
      <div class="bg-gradient-to-r from-brand-dark to-brand-card p-4 border-b border-white/5">
        <div class="flex items-center gap-3">
          <div class="w-1.5 h-6 bg-brand-accent rounded-full shadow-[0_0_8px_#00D1FF]"></div>
          <h2 class="font-black text-white tracking-wide uppercase">Temporadas de Formula 1</h2>
        </div>
      </div>
      <!-- Contenedor del cronograma de eventos -->
      <div class="p-4 space-y-2 grid grid-cols-5 md:grid-cols-7 gap-2">
        {seasons.length > 0 ? (
          seasons.map((season: number) => { 
            return (
              <a href={`/seasons/${season}`}>
                <div class="flex flex-col justify-center items-center border rounded-lg p-4 bg-brand-dark/50 border-white/10">
                  <p class="font-black uppercase tracking-widest text-base text-balance leading-tight text-slate-200">
                    {season}
                  </p>
                </div>
              </a>
            )
          })
        ) : (
          <div class="p-10 flex flex-col items-center text-center">
            <CalendarIcon size="h-12 w-12" extraClass="text-brand-muted mb-4 opacity-50"/>
            <p class="text-brand-muted text-lg font-medium">No hay información sobre las temporadas.</p>
          </div>
        )}
      </div>
    </div>
  </BodyLayout>
</BaseLayout>

